{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPoTCpuBv0/2OF2mSxbcFpf"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":4,"metadata":{"id":"ncKUgm9xpXF6","executionInfo":{"status":"ok","timestamp":1775811791634,"user_tz":-330,"elapsed":4405,"user":{"displayName":"N210214 KATRU RAMYA SRI","userId":"07938608109915245868"}}},"outputs":[],"source":["import os\n","import numpy as np\n","import torch\n","import torch.nn as nn\n","from torch.utils.data import Dataset, DataLoader\n","import matplotlib.pyplot as plt\n","from PIL import Image\n","from skimage.metrics import peak_signal_noise_ratio as psnr\n","from skimage.metrics import structural_similarity as ssim\n","import kagglehub"]},{"cell_type":"code","source":["# Download dataset using kagglehub\n","path = kagglehub.dataset_download(\"andrewmvd/ct-low-dose-reconstruction\")\n","\n","# Correct folder inside dataset\n","data_root = path + \"/Preprocessed_512x512/512\"\n","\n","print(\"Dataset Path:\", data_root)\n","\n","# Verify structure\n","print(os.listdir(data_root))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PvaKJM7Isw35","executionInfo":{"status":"ok","timestamp":1775812333028,"user_tz":-330,"elapsed":538629,"user":{"displayName":"N210214 KATRU RAMYA SRI","userId":"07938608109915245868"}},"outputId":"21b267f2-0fe3-4d09-919b-5b649b9b1a55"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading to /root/.cache/kagglehub/datasets/andrewmvd/ct-low-dose-reconstruction/2.archive...\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 18.3G/18.3G [03:15<00:00, 101MB/s]"]},{"output_type":"stream","name":"stdout","text":["Extracting files...\n"]},{"output_type":"stream","name":"stderr","text":["\n"]},{"output_type":"stream","name":"stdout","text":["Dataset Path: /root/.cache/kagglehub/datasets/andrewmvd/ct-